# TBVision AI Backend — Environment Variables
# Copy this file to .env and fill in your values before running the server.

# ── Supabase (required) ───────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ── JWT (required — change this in production) ────────────────
SECRET_KEY=your-super-secret-key-change-in-production

# ── Anthropic (optional) ─────────────────────────────────────
# If set, Claude Vision is used for accurate X-ray validation.
# If omitted, a pixel-level heuristic fallback is used instead.
ANTHROPIC_API_KEY=
